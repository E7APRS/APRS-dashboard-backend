# Server
PORT=3001

# Allowed CORS origins (comma-separated). Set to your frontend URL in production.
CORS_ORIGINS=http://localhost:3000

# Shared secret for POST /api/gps (sent as X-Api-Key header by DMR-parser and other clients).
# Leave empty to disable auth (development only).
GPS_API_KEY=

# Comment injected into every DMR/DSD+ position (POST /api/gps).
# Leave empty to use whatever comment the client sends.
DMR_COMMENT=E70AB APRS Tracker on 433.500MHz

# Local SQLite (primary database) — file created automatically on first boot
SQLITE_PATH=./data/aprs.db

# Supabase (backup database + auth provider)
SUPABASE_URL=https://your-project.supabase.co
# Use service_role key for backend (Project Settings → API → service_role)
# NEVER expose this key on the frontend
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Feature flag: 'aprsfi' | 'simulator'
DATA_SOURCE=simulator

# APRS.fi API (only used when DATA_SOURCE=aprsfi)
# Get your free key at: https://aprs.fi/account/
APRSFI_API_KEY=your_api_key_here

# Comma-separated callsigns to track (only used when DATA_SOURCE=aprsfi)
APRSFI_CALLSIGNS=E73XYZ,E73ABC,E73DEF

# How often to poll APRS.fi in milliseconds (min 10000 to respect rate limits)
APRSFI_POLL_INTERVAL=15000

# Simulator update interval in milliseconds
SIMULATOR_INTERVAL=5000

# Relay webhook — when set, backend POSTs each new position to this URL (fire-and-forget).
# Used by lora-relay sender. Leave empty to disable.
# RELAY_WEBHOOK_URL=http://localhost:3002/hook/position

# APRS-IS direct TCP connection (only used when DATA_SOURCE=aprsis)
# Supports server-side prefix filters — no need to list exact callsigns
APRSIS_HOST=rotate.aprs2.net
APRSIS_PORT=14580
APRSIS_CALLSIGN=N0CALL        # your own callsign (passcode -1 = receive-only)
# Filter examples:
#   p/E7           → all E7x callsigns (Bosnia)
#   p/E7/9A        → Bosnia + Croatia
#   p/E7/9A/4N     → Bosnia + Croatia + Serbia
#   r/43.85/18.41/100 → 100km radius around Sarajevo
#   p/E7 r/43.85/18.41/200 → combine filters
APRSIS_FILTER=E7

# Meshtastic MQTT bridge (only used when DATA_SOURCES includes 'meshtastic')
# Default connects to the public Meshtastic MQTT broker
MESHTASTIC_MQTT_URL=mqtt://mqtt.meshtastic.org
MESHTASTIC_MQTT_TOPIC=msh/EU_868/2/json/#
MESHTASTIC_MQTT_USER=meshdev
MESHTASTIC_MQTT_PASS=large4cats

# Generic MQTT ingestion (only used when DATA_SOURCES includes 'mqtt')
# Connect to ChirpStack, TTN, or any broker publishing JSON position payloads
# MQTT_BROKER_URL=mqtt://localhost:1883
# MQTT_TOPIC=tracking/#
# MQTT_USERNAME=
# MQTT_PASSWORD=

# TAK Server bridge — push CoT XML over TCP to ATAK
# TAK_ENABLED=true
# TAK_SERVER_HOST=192.168.1.100
# TAK_SERVER_PORT=8087

# CAP (Common Alerting Protocol) alert feed — overlay emergency alerts on the map
# CAP_FEED_URL=https://alerts.meteoalarm.org/feed/cap
# CAP_POLL_INTERVAL=300000

# Federation — comma-separated URLs of other E7APRS backend instances
# Enables multi-site position sync (e.g., repeater site ↔ command center)
# FEDERATION_PEERS=http://192.168.1.50:3001,http://10.0.0.5:3001
